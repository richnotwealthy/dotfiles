#!/bin/bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

info()  { echo -e "${CYAN}::${RESET} $*"; }
warn()  { echo -e "${YELLOW}::${RESET} $*"; }
good()  { echo -e "${GREEN}::${RESET} $*"; }
error() { echo -e "${RED}::${RESET} $*" >&2; }

DOTFILES="$HOME/dotfiles"

info "${BOLD}Installing dotfiles ...${RESET}"

# --- dependencies ---

if command -v apt-get &> /dev/null; then
    info "Installing packages via ${BOLD}apt-get${RESET} ..."
    sudo apt-get update
    sudo apt-get install -y zsh vim tmux git silversearcher-ag fortune-mod cowsay
fi

echo

# --- oh-my-zsh ---

if [ ! -d "$HOME/.oh-my-zsh" ]; then
    if ! command -v curl &> /dev/null; then
        error "${BOLD}curl${RESET} not found, cannot install oh-my-zsh"
        exit 1
    fi
    info "Installing ${BOLD}oh-my-zsh${RESET} ..."
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
else
    info "${BOLD}oh-my-zsh${RESET} already installed"
fi

echo

# --- back up existing configs ---

for f in ~/.vimrc ~/.tmux.conf ~/.zshrc; do
    if [ -f "$f" ] && [ ! -L "$f" ]; then
        mv "$f" "$f.old"
        warn "$(basename "$f"): backed up to ${BOLD}$f.old${RESET}"
    fi
done

# --- symlinks ---

ln -sf "$DOTFILES/vimrc.vim" ~/.vimrc
good ".vimrc: linked to ${BOLD}$DOTFILES/vimrc.vim${RESET}"

ln -sf "$DOTFILES/tmux.conf" ~/.tmux.conf
good ".tmux.conf: linked to ${BOLD}$DOTFILES/tmux.conf${RESET}"

echo

# --- preserve machine defaults ---

if [ -f "$HOME/.zshrc.old" ]; then
    cp "$HOME/.zshrc.old" "$HOME/.zshrc.defaults"
    good ".zshrc.defaults: preserved from ${BOLD}.zshrc.old${RESET}"
elif [ -f "$HOME/.bashrc" ] && [ ! -f "$HOME/.zshrc.defaults" ]; then
    cp "$HOME/.bashrc" "$HOME/.zshrc.defaults"
    good ".zshrc.defaults: preserved from ${BOLD}.bashrc${RESET}"
fi

# --- write zshrc stub ---

cat > ~/.zshrc << 'EOF'
# Machine defaults (preserved from original .zshrc or .bashrc)
if [ -f "$HOME/.zshrc.defaults" ]; then
    source "$HOME/.zshrc.defaults"
fi

export PATH=$HOME/.local/bin:$PATH
export ZSH="$HOME/.oh-my-zsh"

source "$HOME/dotfiles/zshrc.zsh"
EOF
good ".zshrc: written with dotfiles source"

echo

# --- git identity ---

git config --global user.name "Richie Messina"
git config --global user.email "messina.rd@gmail.com"
good "git: identity set to ${BOLD}Richie Messina${RESET}"

# --- default shell ---

if [ "$SHELL" != "$(command -v zsh)" ]; then
    if ! command -v zsh &> /dev/null; then
        error "${BOLD}zsh${RESET} not found, cannot set default shell"
        exit 1
    fi
    chsh -s "$(command -v zsh)"
    good "shell: changed to ${BOLD}zsh${RESET}"
else
    info "shell: already ${BOLD}zsh${RESET}"
fi

echo

good "${BOLD}Done!${RESET} Configs linked to $DOTFILES."
echo
echo "  Next steps:"
echo "    1. Start a new zsh session to see changes"
echo -e "    2. Run ${BOLD}./install-tools${RESET} for extra tooling"
